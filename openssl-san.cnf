[req]
default_bits = 2048
prompt = no
default_md = sha256
req_extensions = req_ext
distinguished_name = dn

[dn]
C = FR
ST = Alsace
L = Strasbourg
O = Bloomly
CN = bloomly-site.local

[req_ext]
subjectAltName = @alt_names

[alt_names]
DNS.1 = bloomly-site.local
DNS.2 = bloomly-static.local
