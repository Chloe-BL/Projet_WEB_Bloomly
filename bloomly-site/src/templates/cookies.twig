{% extends 'layout.twig' %}

{% block title %}Politique des cookies{% endblock %}

{% block body %}

<main>
    <h1>Politique des cookies</h1>

    <section>
        <h2>Qu'est-ce qu'un cookie ?</h2>
        <p class="p-p">
            Un cookie est un petit fichier stocké sur votre appareil pour améliorer votre expérience sur notre site. 
            Il permet de mémoriser vos préférences et de collecter des informations anonymes sur votre navigation.
        </p>
    </section>

    <section>
        <h2>Types de cookies utilisés</h2>
        <ul class="cookie-types">
            <li><strong>Essentiels :</strong> Nécessaires au fonctionnement du site.</li>
            <li><strong>Analytiques :</strong> Nous aident à comprendre comment vous utilisez le site.</li>
            <li><strong>Marketing :</strong> Permettent de proposer du contenu adapté à vos intérêts.</li>
        </ul>
    </section>

    <section>
        <h2>Gérer vos préférences</h2>
        <p class="p-p">
            Vous pouvez accepter ou refuser certains types de cookies à tout moment.
        </p>
        <form class="cookie-preferences">
            <label>
                <input type="checkbox" checked disabled> Essentiels (toujours actifs)
            </label><br>
            <label>
                <input type="checkbox"> Analytiques
            </label><br>
            <label>
                <input type="checkbox"> Marketing
            </label><br>
            <button type="submit" class="btn">Enregistrer mes choix</button>
        </form>
    </section>

    <section>
        <h2>Pourquoi utilisons-nous des cookies ?</h2>
        <p class="p-p">
            Les cookies nous aident à améliorer notre site, à analyser l'utilisation et à proposer des offres et contenus adaptés à vos besoins.
        </p>
    </section>

    <div class="image-placeholder"></div>
</main>

{% endblock %}