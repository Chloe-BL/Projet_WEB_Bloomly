{% extends 'layout.twig' %}

{% block title %}À propos de nous{% endblock %}

{% block body %}

<main class="about-container">

    <h1>À propos de nous</h1>

    <section class="about-section">
        <h2>Notre mission</h2>
        <p>
            Notre site est une plateforme dédiée à la recherche de stages. 
            Nous aidons les étudiants à trouver des opportunités adaptées 
            et les entreprises à recruter facilement.
        </p>
    </section>

    <section class="about-section">
        <h2>Ce que nous proposons</h2>
        <ul>
            <li>🔎 Recherche simplifiée de stages</li>
            <li>🏢 Mise en relation avec les entreprises</li>
            <li>📄 Gestion des candidatures</li>
            <li>👤 Espace personnel pour chaque utilisateur</li>
        </ul>
    </section>

    <section class="about-section">
        <h2>Notre objectif</h2>
        <p>
            Offrir une plateforme moderne, simple et efficace pour 
            faciliter la recherche de stage et améliorer l’expérience utilisateur.
        </p>
    </section>

    <div class="image-placeholder"></div>

</main>

{% endblock %}