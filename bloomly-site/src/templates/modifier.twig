                    </div>
                </div>

                <input type="hidden" name="id_role" value="<?= htmlspecialchars($id_role) ?>">
                <input type="hidden" name="id_createur" value="<?= htmlspecialchars($id_createur) ?>">

{% endif %}

            <button type="submit" class="ajout" name = "form_action" value="ajj_off">Enregistrer</button>
            </form>

{% endblock %}