{% extends 'layout.twig' %}
 
{% block title %}Vos Offres{% endblock %}
 
 
{% block body %}

<form method="post" action="index.php?page=ValidationModif_off&section=offres&connect=oui&user={{user}}"> 

{% else if section == 'offres' %}

        <input type="hidden" name="id_entreprise" value="<?= htmlspecialchars($id_entreprise) ?>">
        
        <label>Nom :</label>
        <input type="text" name="nom" value="<?= htmlspecialchars($user['nom']) ?>">


        <div class="haut-offre">
            <input class="titre" type="text" name="titre" value="<?= htmlspecialchars($user['titre']) ?>">
            <div class="actions">
                <a class="bouton" href="?page=choix_section&section={{section}}">Retour</a>
            </div>
        </div>

        
        <div class="container-flex">
                <div class="cadre">
                    <h1 class="titre">Description entreprise </h1>
                    <input type="text" name="description_ent" value="<?= htmlspecialchars($user['description_ent']) ?>">
                    <p>jsp</p>
                </div>
            </div>

            <div class="categ">
