        <input type="email" name="email_contact" value="<?= htmlspecialchars($user['email_contact']) ?>">
    <br>
        <h4 >Numéro de téléphone : </h4>
        <input type="text" name="telephone_contact" value="<?= htmlspecialchars($user['telephone_contact']) ?>">
    <br>
    </div>

    <div class="categ">
