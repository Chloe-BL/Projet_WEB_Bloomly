                <h4>Rémunération :</h4>
                <input type="text" name="formation" value="<?= htmlspecialchars($user['salaire']) ?>">
            <br>
                <h4>Date de publication :</h4>
                <input type="text" name="formation" value="<?= htmlspecialchars($user['date_pub']) ?>">
            </div>

            <label for="ent">Choisissez une entreprise :</label>
                <select id="ent" name="ent">
                    <option value="<?= htmlspecialchars($user['date_pub']) ?>">
