            <input type="hidden" name="id_createur" value="<?= htmlspecialchars($id_createur) ?>">
            <input type="hidden" name="id_entreprise" value="<?= htmlspecialchars($id_entreprise) ?>">

{% if section == 'entreprises' %}
    <input type="hidden" name="id_entreprise" value="<?= htmlspecialchars($id_entreprise) ?>">
    <div class="haut-offre">
        <input type="text" name="nom" class="titre" value="<?= htmlspecialchars($user['nom']) ?>">
    </div>
    
    <div class="container-flex">
        <div class="cadre">
            <h1 class="titre">Description</h1>
            <input type="text" name="description" value="<?= htmlspecialchars($user['description']) ?>">
        </div>
    </div>

    <div class="categ">
        <hr color=#c06c84 size="2" width="95%" >
        <h1 class="titre">Contacts</h1>
