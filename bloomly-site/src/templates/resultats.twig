{% extends "layout.twig" %}

{% block title %}Résultats de recherche{% endblock %}

{% block body %}

<h1>Résultats pour "{{ search }}"</h1>

{% if resultats is empty %}
    <p>Aucun résultat trouvé.</p>
{% else %}
    {% for item in resultats %}
        <div style="border:1px solid #ccc; padding:15px; margin:10px; border-radius:8px;">

            {% if item.type_result == 'entreprise' or type == 'entreprise' %}
                <span style="background:blue; color:white; padding:3px 8px; border-radius:4px;">Entreprise</span>
                <h3>{{ item.nom ?? item.titre }}</h3>
                <p>{{ item.description }}</p>
                <p>📧 {{ item.email_contact }}</p>
                <p>📞 {{ item.telephone_contact }}</p>

            {% elseif item.type_result == 'offre' or type == 'offre' %}
                <span style="background:green; color:white; padding:3px 8px; border-radius:4px;">Offre</span>
                <h3>{{ item.titre }}</h3>
                <p>{{ item.description }}</p>
                <p>💰 {{ item.salaire }} € | 📅 {{ item.date_pub }}</p>
                <p>🛠 {{ item.competences }}</p>

            {% elseif item.type_result == 'etudiant' or type == 'etudiant' %}
                <span style="background:orange; color:white; padding:3px 8px; border-radius:4px;">Étudiant</span>
                <h3>{{ item.nom }} {{ item.prenom }}</h3>
                <p>📧 {{ item.email }}</p>

            {% elseif item.type_result == 'pilote' or type == 'pilote' %}
                <span style="background:purple; color:white; padding:3px 8px; border-radius:4px;">Pilote</span>
                <h3>{{ item.nom }} {{ item.prenom }}</h3>

            {% else %}
                <h3>{{ item.titre }}</h3>
                <p>{{ item.info }}</p>
            {% endif %}

        </div>
    {% endfor %}
{% endif %}

{% endblock %}