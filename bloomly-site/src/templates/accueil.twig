{% extends 'layout.twig' %}
{% block title %}Accueil{% endblock %}


{% block body %}

<br>
        <h1>Fleurissez votre avenir avec Bloomly</h1>
        <hr color=#c06c84 size="2" width="95%" >

<div class="container-flex">
  <div class="card">
    <img src="http://bloomly-static.local/assets/accueil1.png" alt="Illustration page d'accueil" class="img-acc1">
    <h2>77% des étudiants ont trouvé un stage</h2>
  </div>
  <div class="card stats-card">
  <h2>Nos Statistiques</h2>

  <div class="carousel">
    <button class="carousel-btn prev" onclick="moveSlide(-1)">&#10094;</button>

    <div class="carousel-track-container">
      <div class="carousel-track" id="carouselTrack">
        
        <div class="stat-slide">
  <h3>Durée des stages</h3>
  {% for item in repartition %}
    <p>{{ item.total }} offre(s) : {{ item.duree }} mois</p>
  {% else %}
    <p>Aucune donnée</p>
  {% endfor %}
</div>

<div class="stat-slide">
  <h3>Top wishlist</h3>
  {% for item in topWishlist %}
    <p>{{ loop.index }}. {{ item.titre }}</p>
  {% else %}
    <p>Aucune donnée</p>
  {% endfor %}
</div>

<div class="stat-slide">
  <h3>Offres disponibles</h3>
  <p>{{ totalOffres }} offre(s) en ligne</p>
</div>

<div class="stat-slide">
  <h3>Candidatures moyennes</h3>
  <p>{{ moyenneCandidatures }} candidature(s) / offre</p>
</div>

      </div>
    </div>

    <button class="carousel-btn next" onclick="moveSlide(1)">&#10095;</button>
  </div>

  <div class="carousel-dots">
    <span class="dot active" onclick="goToSlide(0)"></span>
    <span class="dot" onclick="goToSlide(1)"></span>
    <span class="dot" onclick="goToSlide(2)"></span>
    <span class="dot" onclick="goToSlide(3)"></span>
  </div>
</div>

<script>
let currentSlide = 0;
const totalSlides = 4;
setInterval(() => {
    moveSlide(1);
}, 4000);

function updateCarousel() {
    const track = document.getElementById('carouselTrack');
    const dots = document.querySelectorAll('.dot');

    if (!track) return;

    track.style.transform = `translateX(-${currentSlide * 100}%)`;

    dots.forEach((dot, index) => {
        dot.classList.toggle('active', index === currentSlide);
            });
}

function moveSlide(direction) {
    currentSlide = (currentSlide + direction + totalSlides) % totalSlides;
    updateCarousel();
}

function goToSlide(index) {
    currentSlide = index;
    updateCarousel();
}
</script>
  <div class="card">
    <img src="http://bloomly-static.local/assets/accueil2.png" alt="Illustration page d'accueil" class="img-acc2">
    <h2>Plus de 250 entreprises partenaires</h2>
  </div>
</div>
<br>

{% endblock %}


