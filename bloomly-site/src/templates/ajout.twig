{% extends 'layout.twig' %}
{% block title %}ajout{% endblock %}


{% block body %}

{% if section == 'entreprises' %}
        <div class="body_ecart">
        <h2>Ajouter une entreprise !</h2><br>
        <p> Entrez les informations, nous vous confirmerons l'ajout de l'entreprise par email.</p>

        <form method="POST" enctype="mutipart/form-data">
            <div style="display:inline-block;"> <!-- Pour mettre les bloc à côté de l'image -->


                        <label for ="nom">Nom de l'entreprise</label>
                        <input type = "text" name="nom" required>

                   
                        <label for="description">Description</label>
                        <input type = "text" name="description" required>

                        <h2>Informations de contact</h2><br>
                   
                        <label for="email">Email</label>
                        <input type = "email" name="email">
                    
                  
                        <label for="num">Numéro de téléphone</label>
                        <input type = "text" name="num">

                        <label for="adresse">Siège social</label>
                        <input type = "text" name="adresse">                    
                </div>
                </div>
{% endif %}





{% endblock %}