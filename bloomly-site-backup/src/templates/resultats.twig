{% extends "layout.twig" %}
 
{% block title %}Résultats de recherche{% endblock %}
 
{% block body %}
 
<h1>Résultats de recherche</h1>
 
{% if type == 'offre' %}
<div class="contour">
<form method="get" action="index.php">
<input type="hidden" name="page" value="search">
<input type="hidden" name="type" value="offre">
<input type="hidden" name="connect" value="{{ connect }}">
<input type="hidden" name="user" value="{{ user }}">
<div class="ligne">
<div class="bloc">
<label>Nom de l'entreprise</label>
<input type="text" name="entreprise" value="{{ app.request.get('entreprise') ?? '' }}" placeholder="Ex: Google">
</div>
<div class="bloc">
<label>Titre de l'offre</label>
<input type="text" name="search" value="{{ search }}" placeholder="Ex: Développeur">
</div>
<div class="bloc">
<label>Compétences requises</label>
<input type="text" name="competences" value="{{ app.request.get('competences') ?? '' }}" placeholder="Ex: PHP, HTML...">
</div>
</div>
 
        <div class="ligne">
<div class="bloc">
<label>Rémunération</label>
<p><input type="radio" name="salaire" value=""> Aucune</p>
<p><input type="radio" name="salaire" value="smic_moins"> &lt; SMIC</p>
<p><input type="radio" name="salaire" value="smic_plus"> &gt; SMIC</p>
</div>
<div class="bloc">
<label>Date de début</label>
<input type="date" name="date_debut">
</div>
</div>
 
        <button class="large" type="submit">Rechercher</button>
</form>
</div>
{% endif %}
 
{% if resultats is empty %}
<p style="text-align:center; margin-top:30px;">Aucun résultat trouvé.</p>
{% else %}
<div class="liste">
        {% for item in resultats %}
<div class="bloc-liste">
 
                {% if item.type_result == 'entreprise' or type == 'entreprise' %}
<img src="http://bloomly-static.local/assets/annonce.png" alt="Entreprise">
<p><strong>{{ item.nom }}</strong></p>
<p>{{ item.description }}</p>
<p>📧 {{ item.email_contact }}</p>
<p>📞 {{ item.telephone_contact }}</p>
<p>👥 Stagiaires : {{ item.nb_stagiaires }}</p>
<p>⭐ Moyenne : {{ item.moyenne_evaluation ?? 'Aucune' }}/5</p>
 
                {% elseif item.type_result == 'offre' or type == 'offre' %}
<img src="http://bloomly-static.local/assets/annonce.png" alt="Offre">
<p><strong>{{ item.titre }}</strong></p>
<p>🏢 {{ item.entreprise }}</p>
<p>{{ item.description }}</p>
<p>💰 {{ item.salaire }} € | 📅 {{ item.date_pub }}</p>
<p>🛠 {{ item.competences }}</p>
<p>👥 Candidats : {{ item.nb_candidats }}</p>
 
                {% elseif item.type_result == 'etudiant' or type == 'etudiant' %}
<img src="http://bloomly-static.local/assets/profil.png" alt="Étudiant">
<p><strong>{{ item.nom }} {{ item.prenom }}</strong></p>
<p>📧 {{ item.email }}</p>
 
                {% elseif item.type_result == 'pilote' or type == 'pilote' %}
<img src="http://bloomly-static.local/assets/profil.png" alt="Pilote">
<p><strong>{{ item.nom }} {{ item.prenom }}</strong></p>
 
                {% else %}
<p><strong>{{ item.titre }}</strong></p>
<p>{{ item.info }}</p>
                {% endif %}
 
            </div>
        {% endfor %}
</div>
{% endif %}
 
{% endblock %}